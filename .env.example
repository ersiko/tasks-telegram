# Telegram bot token from @BotFather
BOT_TOKEN=

# Your Vikunja instance's API base URL, including /api/v1.
# - Local dev (this machine isn't on Vikunja's Docker network): use the
#   public URL, e.g. https://vikunja.minipc1.tomas.cat/api/v1
# - Deployed via docker-compose.yml alongside Vikunja on minipc1 (joins its
#   "vikunja_default" network): use the internal address instead, since it
#   avoids round-tripping through Traefik/TLS just to reach a sibling
#   container: http://vikunja:3456/api/v1
VIKUNJA_URL=https://vikunja.example.com/api/v1

# Your own numeric Telegram user ID (message the bot with /start once
# deployed to see it, or ask @userinfobot)
ADMIN_TELEGRAM_ID=

# Encryption key for tokens stored at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Project used when a quick-add message doesn't specify one with +project
DEFAULT_PROJECT_NAME=Inbox

# Path to the JSON file storing registered users (Telegram ID -> encrypted
# Vikunja token). docker-compose.yml overrides this to /data/users.json
# (a persisted volume); leave as-is for local runs.
USERS_FILE=users.json

# Time of day (24h, HH:MM) each registered user gets a morning digest of
# tasks due today or overdue - only sent if they actually have any.
DIGEST_TIME=07:00

# IANA timezone the digest time above is interpreted in, e.g. Europe/Madrid.
# Defaults to UTC - set this to your actual timezone, otherwise "07:00"
# means 07:00 UTC, not local time.
DIGEST_TIMEZONE=UTC
