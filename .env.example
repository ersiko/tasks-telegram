# Telegram bot token from @BotFather
BOT_TOKEN=

# Your Vikunja instance's API base URL, including /api/v1.
# - Local dev (this machine isn't on Vikunja's Docker network): use the
#   public URL, e.g. https://vikunja.minipc1.tomas.cat/api/v1
# - Deployed via docker-compose.yml alongside Vikunja on minipc1 (joins its
#   "vikunja_default" network): use the internal address instead, since it
#   avoids round-tripping through Traefik/TLS just to reach a sibling
#   container: http://vikunja:3456/api/v1
VIKUNJA_URL=https://vikunja.example.com/api/v1

# Your own numeric Telegram user ID (message the bot with /start once
# deployed to see it, or ask @userinfobot)
ADMIN_TELEGRAM_ID=

# Encryption key for tokens stored at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Project used when a quick-add message doesn't specify one with +project
DEFAULT_PROJECT_NAME=Inbox

# Project /plan_week (alias /choose_weekly_tasks) picks candidate tasks from
WEEKLY_PROJECT_NAME=Week to Week

# Your recurring day-to-day chores project - used by /pause's catch-up
# behavior (see below): when a pause ends, any open task here that was due
# during the pause gets pushed to become due right when you're back,
# instead of showing up overdue for something that couldn't happen.
DAILY_PROJECT_NAME=Day to Day

# Path to the JSON file storing registered users (Telegram ID -> encrypted
# Vikunja token). docker-compose.yml overrides this to /data/users.json
# (a persisted volume); leave as-is for local runs. The /pause state file
# lives alongside it automatically (digest_pause.json in the same
# directory) - no separate setting needed.
USERS_FILE=users.json

# Time of day (24h, HH:MM) each registered user gets a morning digest of
# tasks due today or overdue - only sent if they actually have any.
DIGEST_TIME=07:00

# IANA timezone used both for the digest time above and for computing
# "today"/"this week" boundaries (/today, /week) and displayed due times,
# e.g. Europe/Madrid. Defaults to UTC - set this to your actual timezone,
# otherwise date/time boundaries and displays will be off by your UTC offset.
TIMEZONE=UTC

# Optional: a Telegram group chat ID to post the morning digest to as one
# combined message (merged across every registered account, deduplicated),
# instead of DMing each registered user individually. Get it by adding the
# bot to the group and running /chatid there. Leave unset to keep the
# per-user DM behavior. Weekly/monthly recap sections (see WEEK_START_DAY
# below) are also only sent this way - group chat only, not per-user DMs.
DIGEST_CHAT_ID=

# Weekday your week "starts" on - drives /week, /plan_week, and which day
# the weekly recap+planning-nudge section gets added to the digest (see
# DIGEST_CHAT_ID). A monthly recap section is added on the 1st of each
# month regardless of this setting. Full weekday name, e.g. Monday.
WEEK_START_DAY=Monday
